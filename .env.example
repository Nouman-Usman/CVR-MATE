DATABASE_URL="Your Database URL here"
# ─── Supabase (video storage) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
BETTER_AUTH_SECRET="your-secret-key-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
CVR_API_KEY="your-cvrapi-token"
GEMINI_API_KEY="your-google-gemini-api-key"
# Redis (optional — app works without it)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
CRON_SECRET=""
# QStash (for scheduled trigger execution — get from console.upstash.com → QStash)
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
CRM_TOKEN_ENCRYPTION_KEY=    # 32-byte hex (generate with: openssl rand -hex 32)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
LEADCONNECTOR_CLIENT_ID=
LEADCONNECTOR_CLIENT_SECRET=
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# ─── Stripe (billing & subscriptions) ───────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=                  # From Stripe Dashboard → Webhooks → Signing secret

# Starter: 299 DKK/month, 2868 DKK/year
NEXT_PUBLIC_STRIPE_STARTER_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_STARTER_ANNUAL_PRICE_ID=

# Professional: 699 DKK/month, 6708 DKK/year
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=

# Enterprise: 1699 DKK/month, 16308 DKK/year
NEXT_PUBLIC_STRIPE_ENT_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENT_ANNUAL_PRICE_ID=

# ─── Resend (primary transactional email) ───────────────────────────────────
RESEND_API_KEY=                         # From resend.com → API Keys
EMAIL_FROM_ADDRESS=                     # Must be a domain verified in Resend (e.g. hello@yourdomain.com)
EMAIL_FROM_NAME="CVR-MATE"             # Display name shown in the From field
RESEND_WEBHOOK_SECRET=                  # From Resend Dashboard → Webhooks → Signing secret (whsec_...)

# ─── Gmail / SMTP (fallback email — used when Resend fails) ─────────────────
# Option A — Gmail App Password (simplest; generate at myaccount.google.com → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                              # Your Gmail address (e.g. you@gmail.com)
SMTP_PASS=                              # App password (16 chars, no spaces)
# Option B — Gmail OAuth2 (more secure for production)
GMAIL_USER=                             # Gmail address for OAuth2
GMAIL_OAUTH2_CLIENT_ID=
GMAIL_OAUTH2_CLIENT_SECRET=
GMAIL_OAUTH2_REFRESH_TOKEN=